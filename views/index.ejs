<% layout("layouts/boilerplate") %>

<div class="row justify-content-center">
  <div class="col-md-6">

    <div class="card shadow p-4">
      <h3 class="text-center mb-3">🔗 URL Shortener</h3>

      <form action="/app/shorten" method="POST">

        <div class="mb-3">
          <input type="text" name="originalUrl" class="form-control"
            placeholder="Enter long URL..." required>
        </div>

        <div class="mb-3">
          <input type="text" name="customCode" class="form-control"
            placeholder="Custom short code (optional)">
        </div>

       <button class="btn btn-primary w-100">
  ✂️ Shorten URL
</button>
      </form>

      <% if (shortUrl) { %>
      <div class="alert alert-success mt-3 text-center">

        <p><strong>Short URL:</strong></p>

        <div class="d-flex gap-2">
          <input type="text" id="shortUrlInput" class="form-control"
            value="<%= shortUrl %>" readonly>

          <button class="btn btn-success" onclick="copyUrl()">Copy</button>
        </div>

        <div class="mt-3">
          <p><strong>QR Code:</strong></p>
          <img src="<%= qrCode %>" width="150">
        </div>

      </div>
      <% } %>
    </div>

    <!-- <div class="mt-4">
      <h5>📊 All URLs</h5>
      <ul class="list-group">
        <% urls.forEach(url => { %>
        <li class="list-group-item d-flex justify-content-between">
          <a href="/<%= url.shortCode %>"><%= url.shortCode %></a>
          <span>Clicks: <%= url.clicks %></span>
        </li>
        <% }) %>
      </ul>
    </div> -->

  </div>
</div>

<script>
function copyUrl() {
  const input = document.getElementById("shortUrlInput");
  input.select();
  document.execCommand("copy");
  alert("Copied!");
}
</script>